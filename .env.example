# Local Postgres — for `docker compose up -d postgres` (see docker-compose.yml), use:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/WEBWEB?schema=public"
#
# If you use pgAdmin / custom instance instead, set user, password, and DB name to match.

JWT_SECRET="change-me-min-32-chars-production-secret-key"
JWT_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_IN="7d"

# Nest listen port — use 3001 if `frontend/.env.local` sets NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=4000
NODE_ENV=development
# Mot de passe du PANNEAU admin (formulaire /admin), pas le hash du compte seed.
# Sur Railway : définir la même valeur que celle saisie sur le site. Défaut si absent : 16061606
ADMIN_PANEL_PASSWORD="16061606"
# Used for emails / redirects. In production include your Vercel URL, e.g. https://your-app.vercel.app
FRONTEND_URL="http://localhost:3000,http://127.0.0.1:3000"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/auth/google/callback"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Gmail : créer un « Mot de passe d'application » (Compte Google → Sécurité).
# Ne commitez jamais le mot de passe ; gardez-le uniquement sur Railway / .env local.
# Le backend accepte aussi EMAIL_USER / EMAIL_PASS / EMAIL_API_KEY (alias de SMTP_USER / SMTP_PASS).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
# Outgoing From is built as "Auto Store" <SMTP_USER> (set SMTP_USER to your Gmail address).
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_API_KEY=""

# Reçoit une copie HTML détaillée de chaque nouvelle commande (défaut : SMTP_USER ou inbox Atlas).
ORDER_NOTIFICATION_EMAIL=""

WHATSAPP_PHONE_E164="212620388209"
WHATSAPP_API_TOKEN=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

CMI_MERCHANT_ID=""
CMI_API_KEY=""

LOYALTY_POINTS_PER_10_MAD=1
