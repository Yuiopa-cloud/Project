# --- Vercel / production (required for /api-proxy → Railway) ---
# Public URL of your Nest API (with or without trailing /api). Used at build time for rewrites.
# Example: https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=

# Optional: origin only (no /api). Overrides proxy target if set. Example: https://xxx.up.railway.app
# BACKEND_PROXY_URL=

# --- Local dev ---
# next dev rewrites /api-proxy → default http://127.0.0.1:4000; override with BACKEND_PROXY_URL if needed.
