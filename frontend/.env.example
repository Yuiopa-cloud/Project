# =============================================================================
# Production (Vercel)
# =============================================================================
# Public URL of your Nest API (no trailing path, or include /api — next.config
# normalizes). Used at **dev/build** time so `/api-proxy/*` rewrites hit Railway.
# Example: https://xxxx.up.railway.app
NEXT_PUBLIC_API_URL=

# Optional: same meaning; preferred if you want a distinct server-only override.
# BACKEND_PROXY_URL=https://xxxx.up.railway.app

# =============================================================================
# Local development (Next.js + local Nest)
# =============================================================================
# The browser always calls same-origin `/api-proxy/...`. Next.js rewrites that
# to your API origin + `/api/...`.
#
# Default when unset (not on Vercel): http://127.0.0.1:4000
#
# If your Nest API runs on another port (e.g. 3001), set ONE of:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
# BACKEND_PROXY_URL=http://127.0.0.1:3001
#
# Restart `npm run dev` after changing this file.

# =============================================================================
# Other
# =============================================================================
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
