// Atlas Auto Morocco — PostgreSQL schema (Prisma)
// Step 2: authoritative data model + indexes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING_CONFIRMATION
  AWAITING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REJECTED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  STRIPE
  CMI
}

enum CouponType {
  PERCENT
  FIXED_MAD
}

enum FraudDecision {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  phone        String    @unique
  passwordHash String?
  firstName    String
  lastName     String
  role         UserRole  @default(CUSTOMER)
  locale       String    @default("fr") // fr | ar
  googleId     String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses          Address[]
  orders             Order[]
  reviews            Review[]
  wishlist           WishlistItem[]
  carts              Cart[]
  refreshTokens      RefreshToken[]
  loyaltyAccount     LoyaltyAccount?
  affiliateProfile    Affiliate?
  fraudReviews        FraudFlag[]        @relation("FraudReviewer")
  loyaltyTransactions LoyaltyTransaction[]
  abandonedCarts      AbandonedCart[]

  @@index([phone])
  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  nameFr    String
  nameAr    String
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  products  Product[]

  @@index([parentId])
  @@index([sortOrder])
}

model Product {
  id                String   @id @default(cuid())
  slug              String   @unique
  sku               String   @unique
  nameFr            String
  nameAr            String
  descriptionFr     String   @db.Text
  descriptionAr     String   @db.Text
  priceMad          Decimal  @db.Decimal(12, 2)
  compareAtMad      Decimal? @db.Decimal(12, 2)
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  purchaseCount     Int      @default(0) // social proof aggregate
  images            String[] // URLs
  isActive          Boolean  @default(true)
  variantsEnabled   Boolean  @default(false)
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  options       ProductOption[]
  variants      ProductVariant[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistedBy  WishlistItem[]
  cartItems     CartItem[]
  views         ProductView[]
  sourceBundles BundleItem[] @relation("BundleSource")
  targetBundles BundleItem[] @relation("BundleTarget")

  @@index([categoryId])
  @@index([isActive])
  @@index([priceMad])
  @@index([createdAt])
}

model ProductOption {
  id        String              @id @default(cuid())
  productId String
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  nameFr    String
  nameAr    String
  sortOrder Int                 @default(0)
  values    ProductOptionValue[]
  selections ProductVariantSelection[]

  @@index([productId])
}

model ProductOptionValue {
  id        String   @id @default(cuid())
  optionId  String
  option    ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  valueFr   String
  valueAr   String
  colorHex  String?
  imageUrl  String?
  sortOrder Int      @default(0)
  selections ProductVariantSelection[]

  @@index([optionId])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku          String   @unique
  priceMad     Decimal? @db.Decimal(12, 2)
  compareAtMad Decimal? @db.Decimal(12, 2)
  stock        Int      @default(0)
  images       String[]
  isDefault    Boolean  @default(false)
  sortOrder    Int      @default(0)
  selections   ProductVariantSelection[]
  cartItems    CartItem[]
  orderItems   OrderItem[]

  @@index([productId])
}

/// One chosen value per option for a variant (e.g. Color=Green, Size=M)
model ProductVariantSelection {
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionId      String
  option        ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionValueId String
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionId])
  @@index([optionValueId])
}

/// “Frequently bought together” — simple graph edges with score
model BundleItem {
  id                String  @id @default(cuid())
  sourceProductId   String
  targetProductId   String
  score             Int     @default(1)
  sourceProduct     Product @relation("BundleSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct     Product @relation("BundleTarget", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId])
  @@index([sourceProductId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  title     String?
  body      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([rating])
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        CouponType
  value       Decimal    @db.Decimal(12, 2)
  minOrderMad Decimal?   @db.Decimal(12, 2)
  maxUses     Int?
  usedCount   Int        @default(0)
  expiresAt   DateTime?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  orders Order[]

  @@index([isActive])
  @@index([expiresAt])
}

model DeliveryZone {
  id                        String  @id @default(cuid())
  cityCode                  String  @unique // e.g. CASA, RABAT
  cityNameFr                String
  cityNameAr                String
  shippingCostMad           Decimal @db.Decimal(12, 2)
  freeShippingThresholdMad  Decimal? @db.Decimal(12, 2)
  isActive                  Boolean @default(true)

  orders Order[]

  @@index([isActive])
}

/// Moroccan-friendly address: quarter + city code + optional postal
model Address {
  id           String  @id @default(cuid())
  userId       String?
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  label        String  @default("Domicile")
  line1        String
  line2        String?
  quarter      String // neighbourhood / quartier
  cityCode     String
  postalCode   String?
  phone        String
  instructions String? @db.Text
  isDefault    Boolean @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([cityCode])
}

model Cart {
  id          String     @id @default(cuid())
  userId      String?    @unique
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestToken  String?    @unique
  updatedAt   DateTime   @updatedAt
  items       CartItem[]

  @@index([guestToken])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  cart      Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  /// Stable key: variantId or `base:${productId}` when the product has no variants
  lineKey   String
  quantity  Int    @default(1)

  @@unique([cartId, lineKey])
  @@index([productId])
}

model Order {
  id                         String          @id @default(cuid())
  orderNumber                String          @unique
  userId                     String?
  user                       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail                 String?
  guestPhone                 String
  status                     OrderStatus     @default(PENDING_CONFIRMATION)
  paymentMethod              PaymentMethod   @default(CASH_ON_DELIVERY)
  subtotalMad                Decimal         @db.Decimal(12, 2)
  shippingMad                Decimal         @db.Decimal(12, 2)
  discountMad                Decimal         @default(0) @db.Decimal(12, 2)
  totalMad                   Decimal         @db.Decimal(12, 2)
  couponId                   String?
  coupon                     Coupon?         @relation(fields: [couponId], references: [id])
  deliveryZoneId             String
  deliveryZone               DeliveryZone    @relation(fields: [deliveryZoneId], references: [id])
  shippingAddress            Json // snapshot at checkout
  phoneConfirmed             Boolean         @default(false)
  manualConfirmationRequired Boolean         @default(false)
  fraudScore                 Int             @default(0) // 0-100
  adminNotes                 String?         @db.Text
  affiliateCode              String?
  loyaltyPointsEarned        Int             @default(0)
  stripePaymentIntentId      String?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  items       OrderItem[]
  fraudFlags  FraudFlag[]
  loyaltyTx   LoyaltyTransaction[]
  referralHit ReferralEvent?

  @@index([userId])
  @@index([guestPhone])
  @@index([status])
  @@index([createdAt])
  @@index([manualConfirmationRequired])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantLabel   String?
  quantity       Int
  unitPriceMad   Decimal @db.Decimal(12, 2)
  titleSnapshot  String

  @@index([orderId])
  @@index([productId])
}

model FraudFlag {
  id         String        @id @default(cuid())
  orderId    String        @unique
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reasons    String[]
  score      Int
  decision   FraudDecision @default(PENDING)
  reviewedById String?
  reviewedBy User?         @relation("FraudReviewer", fields: [reviewedById], references: [id])
  reviewedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([decision])
}

model WishlistItem {
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, productId])
  @@index([productId])
}

model LoyaltyAccount {
  userId  String @id
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance Int    @default(0)
  updatedAt DateTime @updatedAt
}

model LoyaltyTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orderId])
}

model Affiliate {
  id                String   @id @default(cuid())
  userId            String?  @unique
  user              User?    @relation(fields: [userId], references: [id])
  code              String   @unique
  displayName       String
  commissionPercent Decimal  @db.Decimal(5, 2)
  isActive          Boolean  @default(true)
  events            ReferralEvent[]

  @@index([isActive])
}

model ReferralEvent {
  id           String    @id @default(cuid())
  affiliateId  String
  affiliate    Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  orderId      String?   @unique
  order        Order?    @relation(fields: [orderId], references: [id])
  convertedAt  DateTime  @default(now())

  @@index([affiliateId])
}

model AbandonedCart {
  id              String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestToken      String?
  email           String?
  itemsSnapshot   Json
  lastSeenAt      DateTime  @default(now())
  recoveredOrderId String?

  @@index([email])
  @@index([lastSeenAt])
  @@index([guestToken])
}

model ProductView {
  id          String   @id @default(cuid())
  userId      String?
  guestToken  String?
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt    DateTime @default(now())

  @@index([userId, viewedAt])
  @@index([guestToken, viewedAt])
  @@index([productId])
}
